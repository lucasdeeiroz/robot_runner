{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Robot Runner",
  "version": "2.3.1-alpha3",
  "identifier": "com.lucasdeeiroz.robotrunner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Robot Runner",
        "width": 1200,
        "height": 800,
        "minWidth": 620,
        "minHeight": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: https://api.github.com https://generativelanguage.googleapis.com https://api.openai.com https://api.anthropic.com https://*.firebaseio.com https://*.googleapis.com https://*.firebaseapp.com https://www.google-analytics.com https://region1.google-analytics.com"
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "../scripts/web_capture.cjs",
      "../scripts/web_interaction.cjs",
      "../scripts/web_record.cjs"
    ],
    "targets": [
      "nsis",
      "appimage",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Lucas de Eiroz Rodrigues"
  }
}
